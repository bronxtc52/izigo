# OS
.DS_Store

# Архивы исходных распаковок
*.zip

# Ресёрч-кэш Firecrawl
.firecrawl/

# Зависимости (подстраховка к вложенным .gitignore подпроектов)
**/vendor/
**/node_modules/
**/.next/

# Секреты и локальные конфиги
**/.env
**/.env.local
**/.env.*.local
# Защитная сетка: плейнтекст-секреты не коммитим (источник секретов — Azure Key Vault)
**/*api*.txt
**/*token*.txt
**/*secret*.txt
docs/tg*.txt

# Laravel runtime
**/storage/*.key
**/database/*.sqlite

# Логи
*.log

# артефакты прогонов multi-llm-reviewer
.review/
