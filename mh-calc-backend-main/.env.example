APP_NAME="IziGo Calculator"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# БД — PostgreSQL (ltree обязателен для дерева структуры; MySQL/SQLite не подходят).
# В проде креды инжектятся из Key Vault; локально/тесты — заполнить.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=izigo
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Telegram-auth (Modules/Calculator/Config/config.php) ────────────────────
# Токен бота — ТОЛЬКО из Key Vault (izigo--beta--TELEGRAM-BOT-TOKEN), инжектится env; не хардкод.
TELEGRAM_BOT_TOKEN=
# Макс. возраст initData/Login-Widget (сек) против replay. Дефолт 1ч.
TELEGRAM_INITDATA_MAX_AGE=3600
TELEGRAM_LOGIN_MAX_AGE=3600
# TTL Sanctum-токена веб-админки (минуты). 0 = бессрочный.
WEB_ADMIN_TOKEN_TTL_MINUTES=720
# Бутстрап владельцев: telegram_id через запятую — из Key Vault (izigo--beta--OWNER-TELEGRAM-IDS).
OWNER_TELEGRAM_IDS=
# Исходящие уведомления в Telegram (opt-in; в тестах/локально выключено).
TELEGRAM_NOTIFY_ENABLED=false
# username бота (без @) и short-name Mini App (BotFather) — ПУБЛИЧНЫЕ, не секреты.
TELEGRAM_BOT_USERNAME=Izigopro_mlm_bot
TELEGRAM_MINIAPP_SHORT_NAME=app

# ── Домен / тест ────────────────────────────────────────────────────────────
# Мок-активация пакета БЕЗ оплаты — ТОЛЬКО тест-окружение. В проде true = печать денег (deny-by-default).
CALCULATOR_ALLOW_MOCK_ACTIVATION=false
# Лид-окно (дни): срок закрепления лида за спонсором до первой покупки.
LEAD_WINDOW_DAYS=7

# ── Commerce / приём TON Pay ────────────────────────────────────────────────
# Учётная валюта commerce (стейблкоин USDT в сети TON).
COMMERCE_CURRENCY=USDT
# Драйвер приёма: ton_pay (боевой) | ton_pay_fake | fake (тесты/dev).
PAYMENT_GATEWAY=ton_pay
# TTL «висящих» pending-платежей (минуты). 0 = не истекать.
PAYMENT_PENDING_TTL_MINUTES=1440
# Наш merchant-адрес получателя — из Key Vault (izigo--beta--TON-MERCHANT-ADDRESS).
TON_MERCHANT_ADDRESS=
# Ключ к TON API для опроса сети — из Key Vault (izigo--beta--TON-API-KEY).
TON_API_KEY=
# База toncenter v3 (приём структурированных jetton-переводов).
TON_API_V3_BASE_URL=https://toncenter.com/api/v3
# Мастер-контракт USDT-джеттона (TON), decimals=6 — ПУБЛИЧНЫЙ параметр.
TON_USDT_JETTON_MASTER=
# Секрет подписи входящего платёжного webhook. Wallet Pay отключён, ключ юзает FakeGateway в тестах.
WALLETPAY_WEBHOOK_SECRET=

# ── Выплаты / KYC ───────────────────────────────────────────────────────────
# On-chain выплаты USDT (TON). Драйвер: ton_usdt (боевой) | fake. Выплаты — вручную by design.
PAYOUT_GATEWAY=ton_usdt
# КРИТИЧНЫЙ секрет hot-wallet — из Key Vault (izigo--beta--TON-PAYOUT-WALLET-KEY). НИКОГДА в plain.
TON_PAYOUT_WALLET_KEY=
TON_PAYOUT_WALLET_ADDRESS=
# База toncenter v2 (payout).
TON_API_BASE_URL=https://toncenter.com/api/v2
# Порог суммы (USDT-центы), выше которого нужен одобренный KYC.
# ВАЖНО: ключ читается как env(...) !== null — поэтому «выключено» = ОТСУТСТВИЕ ключа (строка
# закомментирована), а НЕ пустое значение (пустая строка → (int)0 → KYC для любого вывода).
# Задать боевой порог только в реальном .env/keyvaultref, здесь держим закомментированным.
# KYC_THRESHOLD_CENTS=
# Приватный ключ расшифровки Telegram Passport — из Key Vault (izigo--beta--PASSPORT-PRIVATE-KEY).
PASSPORT_PRIVATE_KEY=

# ── Sentry ──────────────────────────────────────────────────────────────────
# DSN — из Key Vault: izigo--beta--SENTRY-DSN. PII не шлём.
SENTRY_LARAVEL_DSN=
# Совместимость: часть кода читает SENTRY_DSN (тот же izigo--beta--SENTRY-DSN).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SEND_DEFAULT_PII=false

# AI-ассистент партнёра. Ключ — ТОЛЬКО из Key Vault (izigo--prod--ANTHROPIC-API-KEY).
# В local-разработке задать в .env (НЕ коммитить реальный ключ).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ASSISTANT_RATE_PER_MINUTE=10
