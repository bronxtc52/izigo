# IziGo Telegram bot worker (grammY, long-polling, без ingress).
# Секретов тут НЕТ: сам токен бота и DSN тянутся из Azure Key Vault по ИМЕНИ секрета
# через managed identity / DefaultAzureCredential в рантайме (src/config.js).

# Имя Key Vault, откуда читаются секреты (дефолт в коде — kv-bronxtc-dev).
KEY_VAULT_NAME=kv-bronxtc-dev
# Имя секрета с токеном бота в Key Vault (НЕ сам токен).
BOT_TOKEN_SECRET_NAME=izigo--beta--TELEGRAM-BOT-TOKEN
# Имя секрета с Sentry DSN (self-host sentry.adarasoft.com), опционален.
# Код-дефолт (src/config.js) — izigo--beta--SENTRY-DSN (общий проект бэка/бота).
SENTRY_DSN_SECRET_NAME=izigo--beta--SENTRY-DSN-BOT

# URL Mini App (https). Без него кнопка запуска приложения не показывается.
MINI_APP_URL=

# Окружение для тегов Sentry (environment).
APP_ENV=beta
# Git SHA сборки для release-тега Sentry (проставляется в CI).
GIT_SHA=
