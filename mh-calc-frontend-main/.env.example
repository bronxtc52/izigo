NEXT_PUBLIC_SERVER_BACK_URL=http://api.localhost:3000
NEXT_PUBLIC_SERVER_FRONT_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_MAIN_PROJECT=http://localhost:4000
NEXT_PUBLIC_SERVER_PROD=false

# TON / TonConnect — ПУБЛИЧНЫЕ параметры (НЕ секреты; ключей/токенов тут быть не должно).
# Сеть: mainnet | testnet (должна совпадать с merchant-кошельком бэкенда).
NEXT_PUBLIC_TON_NETWORK=mainnet
# RPC для резолва jetton-кошелька отправителя. ТОЛЬКО keyless/публичный endpoint или свой
# бэкенд-прокси — API-ключ toncenter в фронт НЕ кладём (секреты — в Key Vault).
NEXT_PUBLIC_TON_RPC=
# Адрес мастер-контракта USDT-джеттона (TON). decimals=6.
NEXT_PUBLIC_USDT_JETTON_MASTER=

# Telegram — ПУБЛИЧНЫЕ параметры (запекаются на build; имена 1:1 с ARG в Dockerfile).
# username бота (без @) для Login Widget веб-админки.
NEXT_PUBLIC_TG_BOT_USERNAME=
# twaReturnUrl для TonConnect (возврат в Mini App после кошелька).
NEXT_PUBLIC_TWA_RETURN_URL=

# Sentry фронта (izigo-frontend). DSN ПУБЛИЧНЫЙ по природе — build-arg, не секрет.
# Значение — из Key Vault izigo--beta--SENTRY-DSN-FRONTEND (gh secret FRONTEND_SENTRY_DSN).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=beta
# release = GITHUB_SHA (проставляется в CI).
NEXT_PUBLIC_SENTRY_RELEASE=

# Build/CI-only (НЕ NEXT_PUBLIC, в образ не запекаются; значения — из CI/Key Vault):
# SENTRY_AUTH_TOKEN   — только CI/Key Vault, аплоад sourcemaps (в билде образа выключен)
# SENTRY_URL=https://sentry.adarasoft.com
